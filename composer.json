{
    "name": "leomottarocha/cotidiano",
    "description": "Classe desenvolvida para rotinas do cotidiano",
    "type": "project",
    "keywords": [
        "php",
        "cotidiano",
        "helpers",
        "rotinas",
        "utilities"
    ],
    "homepage": "https://github.com/leomottarocha/cotidiano",
    "license": "MIT",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "squizlabs/php_codesniffer": "^3.10",
        "friendsofphp/php-cs-fixer": "^3.64",
        "phpstan/phpstan": "^1.12"
    },
    "autoload": {
        "psr-4": {
            "Source\\": "source/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Léo Motta Rocha",
            "email": "leomottarocha@hotmail.com",
            "homepage": "https://github.com/leomottarocha",
            "role": "Desenvolvedor Full Stack"
        }
    ],
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "platform-check": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "scripts": {
        "test": "phpunit",
        "stan": "phpstan analyse",
        "cs": "phpcs",
        "fix": "php-cs-fixer fix",
        "dump": "composer dump-autoload -o"
    },
    "scripts-descriptions": {
        "test": "Executa os testes unitários",
        "stan": "Executa análise estática com PHPStan",
        "cs": "Verifica padronização de código com PHP_CodeSniffer",
        "fix": "Corrige estilo de código com PHP-CS-Fixer",
        "dump": "Regera o autoload otimizado"
    },
    "support": {
        "issues": "https://github.com/leomottarocha/cotidiano/issues",
        "source": "https://github.com/leomottarocha/cotidiano"
    }
}